{
  "name": "@apeira/core",
  "type": "module",
  "version": "0.0.7",
  "description": "stream-first Agent Runtime.",
  "author": "Moeru AI",
  "license": "MIT",
  "homepage": "https://github.com/moeru-ai/apeira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeru-ai/apeira.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/moeru-ai/apeira/issues",
  "keywords": [
    "agent",
    "ai",
    "xsai"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./chat": "./src/chat.ts",
    "./responses": "./src/responses.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./chat": {
        "types": "./dist/chat.d.ts",
        "default": "./dist/chat.js"
      },
      "./responses": {
        "types": "./dist/responses.d.ts",
        "default": "./dist/responses.js"
      },
      "./package.json": "./package.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "pkgroll",
    "test": "vitest run"
  },
  "dependencies": {
    "@xsai-ext/responses": "catalog:xsai",
    "@xsai/shared": "catalog:xsai",
    "@xsai/shared-chat": "catalog:xsai",
    "@xsai/stream-text": "catalog:xsai",
    "@xsai/tool": "catalog:xsai",
    "yocto-queue": "catalog:"
  },
  "devDependencies": {
    "@moeru/std": "catalog:"
  }
}
