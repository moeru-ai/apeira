{
  "name": "@apeira/core",
  "type": "module",
  "version": "0.0.4",
  "description": "stream-first Agent Runtime.",
  "author": "Moeru AI",
  "license": "MIT",
  "homepage": "https://github.com/moeru-ai/apeira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeru-ai/apeira.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/moeru-ai/apeira/issues",
  "keywords": [
    "agent",
    "ai",
    "xsai"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./episodic": "./src/episodic.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./episodic": {
        "types": "./dist/episodic.d.ts",
        "default": "./dist/episodic.js"
      },
      "./package.json": "./package.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "pkgroll",
    "test": "vitest run"
  },
  "dependencies": {
    "@moeru/std": "catalog:",
    "@xsai-ext/responses": "catalog:xsai",
    "@xsai/shared": "catalog:xsai",
    "@xsai/shared-chat": "catalog:xsai",
    "yocto-queue": "catalog:"
  }
}
