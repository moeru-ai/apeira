      "./auto-review": {
        "types": "./dist/auto-review/index.d.ts",
        "default": "./dist/auto-review/index.js"
      },
      "./package.json": "./package.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "pkgroll --clean-dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@apeira/core": "workspace:",
    "@apeira/plugin-sandbox": "workspace:"
  },
  "peerDependenciesMeta": {
