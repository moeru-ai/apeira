{
  "name": "@apeira/plugin-hitl",
  "type": "module",
  "version": "0.0.7",
  "private": true,
  "description": "Human-in-the-loop tool and sandbox permission approval for Apeira.",
  "author": "Moeru AI",
  "license": "MIT",
  "homepage": "https://github.com/moeru-ai/apeira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeru-ai/apeira.git",
    "directory": "packages/plugin-hitl"
  },
  "bugs": "https://github.com/moeru-ai/apeira/issues",
  "keywords": [
    "agent",
    "ai",
    "xsai",
    "hitl"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./auto-review": "./src/auto-review/index.ts",
