{
  "name": "@apeira/workspace",
  "type": "module",
  "version": "0.0.4",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:docs": "vitepress build docs",
    "bump": "bumpp",
    "dev:chat-sdk": "pnpm -F @apeira/example-chat-sdk dev",
    "dev:copilotkit": "pnpm -F @apeira/example-copilotkit dev",
    "dev:docs": "vitepress dev docs",
    "dev:pi-tui": "pnpm -F @apeira/example-pi-tui dev",
    "lint": "eslint --flag unstable_native_nodejs_ts_config --cache .",
    "preview:docs": "vitepress preview docs",
    "test": "pnpm -r test"
