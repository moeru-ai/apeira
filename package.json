    "@types/node": "catalog:",
    "@unocss/eslint-plugin": "catalog:",
    "@unocss/reset": "catalog:",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "pkgroll": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unocss": "catalog:",
    "unocss-preset-animations": "catalog:",
    "unocss-preset-shadcn": "catalog:",
    "vite": "catalog:",
    "vitepress": "catalog:",
    "vitest": "catalog:"
  }
